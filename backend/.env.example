SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave empty to use local SQLite. For Postgres / Railway:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# Cloudflare R2 — required for cloud image storage
# Create API token in Cloudflare → R2 → Manage R2 API Tokens (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=toolsnest-media
# Public URL from R2 bucket → Settings → Public access (r2.dev) or custom domain
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
# API endpoint (NOT the public URL):
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# Seed admin (used by seed_catalog)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@toolsnest.tools
ADMIN_PASSWORD=admin123

# Owner WhatsApp number in international format without +
# Example Pakistan: 923363399445
WHATSAPP_OWNER_NUMBER=
